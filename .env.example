# RentKeepers Configuration

# Flask Secret Key (change this to something random!)
SECRET_KEY=your-secret-key-here-change-me

# Email Configuration (for reminder emails)
# For Gmail, use an App Password (not your regular password)
# Get one at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# Or for other providers:
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_DEFAULT_SENDER=rentkeepers@example.com

# Note: Create this file as ".env" in the rentkeepers directory
# Do not commit this file to git!
