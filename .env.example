# RentKeepers Configuration Template
# ================================
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env TO GIT!

# =============================================================================
# REQUIRED
# =============================================================================

# Flask Secret Key - generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-me

# Database - Railway auto-sets DATABASE_URL, or use locally:
# DATABASE_URL=sqlite:///rentkeepers.db

# =============================================================================
# OPTIONAL: Email (for rent reminders)
# =============================================================================

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER=your_email@gmail.com

# =============================================================================
# OPTIONAL: Stripe (for payments)
# =============================================================================

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# =============================================================================
# OPTIONAL: AWS S3 (for backups)
# =============================================================================

AWS_S3_BACKUP_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1